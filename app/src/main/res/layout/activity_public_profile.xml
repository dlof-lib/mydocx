<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper_50"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/ink_900" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/ink_900"
            android:orientation="vertical"
            android:paddingBottom="20dp"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/imgAvatar"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/avatar_circle_bg"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvFullName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/paper_50"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="خالد المطيري" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9FB0C2"
                android:textSize="13sp"
                tools:text="@khaled" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout android:id="@+id/btnFollowers" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:paddingHorizontal="18dp">
                    <TextView android:id="@+id/tvFollowersCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/paper_50" android:textStyle="bold" android:textSize="16sp" tools:text="80" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/followers" android:textColor="#9FB0C2" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btnFollowing" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:paddingHorizontal="18dp">
                    <TextView android:id="@+id/tvFollowingCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/paper_50" android:textStyle="bold" android:textSize="16sp" tools:text="20" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/followed" android:textColor="#9FB0C2" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFollow"
                style="@style/Btn.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:paddingHorizontal="28dp"
                android:text="@string/follow" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_shape"
            android:layout_margin="12dp"
            android:padding="14dp"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/about" android:textColor="@color/ink_900" android:textStyle="bold" android:textSize="14sp" />
            <TextView android:id="@+id/tvBio" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="13sp"
                tools:text="نبذة عن المستخدم" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_shape"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:padding="14dp"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/social_links" android:textColor="@color/ink_900" android:textStyle="bold" android:textSize="14sp" />
            <LinearLayout android:id="@+id/socialLinksContainer" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="6dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            android:text="@string/reposts_section"
            android:textColor="@color/ink_900"
            android:textStyle="bold"
            android:textSize="15sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerReposts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="24dp" />
    </LinearLayout>
</ScrollView>
