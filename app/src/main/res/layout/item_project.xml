<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_shape"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="10dp"
    android:padding="14dp"
    android:elevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgAvatarView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:background="@drawable/avatar_circle_bg" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAuthorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink_900"
                android:textStyle="bold"
                android:textSize="14sp"
                tools:text="خالد المطيري" />

            <TextView
                android:id="@+id/tvUsernameTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                tools:text="@u.khaled · منذ يوم" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnFollow"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_follow_add"
            android:contentDescription="@string/follow" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvProjectName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_900"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text="MyProject.docx" />

        <TextView
            android:id="@+id/tvLanguageBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/badge_project"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="@color/gold_accent"
            android:textSize="10sp"
            tools:text="Kotlin" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="3"
        android:ellipsize="end"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        tools:text="وصف مختصر عن المشروع والتقنيات المستخدمة فيه…" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadStructured"
            style="@style/Btn.Outline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            app:icon="@drawable/ic_download_structured"
            app:iconGravity="textStart"
            android:text="@string/download_structured" />
    </LinearLayout>

    <include layout="@layout/include_reaction_bar" />
</LinearLayout>
