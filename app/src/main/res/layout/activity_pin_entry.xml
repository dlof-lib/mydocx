<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ink_900"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingTop="64dp"
    android:paddingBottom="24dp">

    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_pin_lock" />

    <TextView
        android:id="@+id/tvPinTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/red_passkey_title"
        android:textColor="@color/paper_50"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPinDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:text="@string/red_passkey_desc"
        android:textColor="#9FB0C2"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal">

        <View android:id="@+id/dot1" android:layout_width="16dp" android:layout_height="16dp"
            android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot2" android:layout_width="16dp" android:layout_height="16dp"
            android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot3" android:layout_width="16dp" android:layout_height="16dp"
            android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot4" android:layout_width="16dp" android:layout_height="16dp"
            android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPinError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/signal_red"
        android:textSize="13sp"
        android:visibility="invisible" />

    <EditText
        android:id="@+id/hiddenPinInput"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:maxLength="4"
        android:inputType="numberPassword"
        android:alpha="0" />

    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <GridLayout
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginBottom="24dp">

        <Button android:id="@+id/key1" style="?android:attr/borderlessButtonStyle" android:text="1" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key2" style="?android:attr/borderlessButtonStyle" android:text="2" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key3" style="?android:attr/borderlessButtonStyle" android:text="3" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key4" style="?android:attr/borderlessButtonStyle" android:text="4" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key5" style="?android:attr/borderlessButtonStyle" android:text="5" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key6" style="?android:attr/borderlessButtonStyle" android:text="6" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key7" style="?android:attr/borderlessButtonStyle" android:text="7" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key8" style="?android:attr/borderlessButtonStyle" android:text="8" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key9" style="?android:attr/borderlessButtonStyle" android:text="9" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <View android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/key0" style="?android:attr/borderlessButtonStyle" android:text="0" android:textColor="@color/paper_50" android:textSize="22sp" android:layout_width="80dp" android:layout_height="64dp"/>
        <Button android:id="@+id/keyBack" style="?android:attr/borderlessButtonStyle" android:text="⌫" android:textColor="@color/signal_red" android:textSize="20sp" android:layout_width="80dp" android:layout_height="64dp"/>
    </GridLayout>
</LinearLayout>
