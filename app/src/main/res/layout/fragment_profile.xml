<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper_50"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/ink_900"
            android:orientation="vertical"
            android:paddingBottom="20dp"
            android:paddingTop="24dp"
            android:gravity="center_horizontal">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/avatar_circle_bg"
                    android:scaleType="centerCrop" />

                <ImageButton
                    android:id="@+id/btnDownloadAvatar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/pin_dot_filled"
                    android:padding="6dp"
                    android:src="@drawable/ic_download_structured"
                    android:contentDescription="@string/download_avatar" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvFullName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/paper_50"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="سارة أحمد" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9FB0C2"
                android:textSize="13sp"
                tools:text="@sara" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btnFollowers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="18dp">
                    <TextView android:id="@+id/tvFollowersCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/paper_50" android:textStyle="bold" android:textSize="16sp" tools:text="128" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/followers" android:textColor="#9FB0C2" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnFollowing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="18dp">
                    <TextView android:id="@+id/tvFollowingCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/paper_50" android:textStyle="bold" android:textSize="16sp" tools:text="54" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/followed" android:textColor="#9FB0C2" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditProfile"
                style="@style/Btn.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="24dp"
                android:text="@string/edit_profile" />
        </LinearLayout>

        <!-- About -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_shape"
            android:layout_margin="12dp"
            android:padding="14dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about"
                android:textColor="@color/ink_900"
                android:textStyle="bold"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="مطوّرة أندرويد، أحب توثيق الأفكار ومشاركة المشاريع مفتوحة المصدر." />
        </LinearLayout>

        <!-- Special thanks -->
        <LinearLayout
            android:id="@+id/sectionThanks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_shape"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:padding="14dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/special_thanks"
                android:textColor="@color/ink_900"
                android:textStyle="bold"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvSpecialThanks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="شكر خاص لفريق كذا ولكل من دعمني." />
        </LinearLayout>

        <!-- Social links -->
        <LinearLayout
            android:id="@+id/sectionLinks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_shape"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:padding="14dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/social_links"
                android:textColor="@color/ink_900"
                android:textStyle="bold"
                android:textSize="14sp" />
            <LinearLayout
                android:id="@+id/socialLinksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Monthly email subscription -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_shape"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:padding="14dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/monthly_subscription"
                android:textColor="@color/ink_900"
                android:textStyle="bold"
                android:textSize="14sp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input.Field"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/subscribe_email_hint">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputSubscribeEmail"
                        android:inputType="textEmailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubscribe"
                    style="@style/Btn.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/subscribe" />
            </LinearLayout>
        </LinearLayout>

        <!-- Reposts section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            android:text="@string/reposts_section"
            android:textColor="@color/ink_900"
            android:textStyle="bold"
            android:textSize="15sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerReposts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="24dp" />
    </LinearLayout>
</ScrollView>
