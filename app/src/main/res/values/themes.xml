<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MyDocx" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ink_800</item>
        <item name="colorPrimaryDark">@color/ink_900</item>
        <item name="colorAccent">@color/signal_red</item>
        <item name="android:windowBackground">@color/paper_50</item>
        <item name="android:statusBarColor">@color/ink_900</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <style name="Theme.MyDocx.Splash" parent="Theme.MyDocx">
        <item name="android:windowBackground">@drawable/bg_splash</item>
    </style>

    <style name="Btn.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/signal_red</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Btn.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/ink_600</item>
        <item name="android:textColor">@color/ink_700</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Input.Field" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/ink_600</item>
    </style>
</resources>
